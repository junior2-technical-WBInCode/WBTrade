// ---------- Support Messaging System ----------
model SupportTicket {
  id             String         @id @default(cuid())
  ticketNumber   String         @unique @map("ticket_number")
  userId         String?        @map("user_id")
  guestEmail     String?        @map("guest_email")
  orderId        String?        @map("order_id")
  subject        String
  category       TicketCategory @default(GENERAL)
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(NORMAL)
  isArchived     Boolean        @default(false) @map("is_archived")
  archivedAt     DateTime?      @map("archived_at")
  lastMessageAt  DateTime       @default(now()) @map("last_message_at")
  closedAt       DateTime?      @map("closed_at")
  closedBy       String?        @map("closed_by")
  returnNumber   String?        @unique @map("return_number")
  guestName      String?        @map("guest_name")
  guestPhone     String?        @map("guest_phone")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  messages       SupportMessage[]

  returnRequest  ReturnRequest? 
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order          Order?         @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([category])
  @@index([ticketNumber])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@index([isArchived])
  @@map("support_tickets")
}

model SupportMessage {
  id         String        @id @default(cuid())
  ticketId   String        @map("ticket_id")
  senderId   String?       @map("sender_id")
  senderRole MessageSender @default(CUSTOMER) @map("sender_role")
  content    String
  isRead     Boolean       @default(false) @map("is_read")
  readAt     DateTime?     @map("read_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@index([isRead])
  @@index([createdAt])
  @@map("support_messages")
}

enum TicketCategory {
  ORDER
  DELIVERY
  COMPLAINT
  RETURN
  PAYMENT
  ACCOUNT
  GENERAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
}

enum MessageSender {
  CUSTOMER
  ADMIN
  SYSTEM
}

// ============================================
// RETURNS / REFUNDS
// ============================================

enum ReturnStatus {
  NEW
  RECEIVED
  APPROVED
  REFUND_SENT
  CLOSED
  REJECTED
}

model ReturnRequest {
  id              String        @id @default(cuid())
  returnNumber    String        @unique @map("return_number")
  orderId         String        @map("order_id")
  ticketId        String        @unique @map("ticket_id")
  status          ReturnStatus  @default(NEW)
  type            TicketCategory // RETURN or COMPLAINT
  reason          String
  refundAmount    Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  refundDate      DateTime?     @map("refund_date")
  adminNotes      String?       @map("admin_notes")
  rejectionReason String?       @map("rejection_reason")
  closedAt        DateTime?     @map("closed_at")
  closedBy        String?       @map("closed_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  order           Order         @relation(fields: [orderId], references: [id])
  ticket          SupportTicket @relation(fields: [ticketId], references: [id])
  items           ReturnItem[]

  @@index([orderId])
  @@index([ticketId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("return_requests")
}

model ReturnItem {
  id              String     @id @default(cuid())
  returnRequestId String     @map("return_request_id")
  orderItemId     String     @map("order_item_id")
  quantity        Int
  reason          String?
  createdAt       DateTime   @default(now()) @map("created_at")

  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])

  @@index([returnRequestId])
  @@index([orderItemId])
  @@map("return_items")
}

// ============================================
// SALE CAMPAIGNS (Przeceny)
// ============================================

model SaleCampaign {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  discountType        DiscountType         @default(PERCENTAGE) @map("discount_type")
  discountValue       Decimal              @map("discount_value") @db.Decimal(10, 2)
  roundTo99           Boolean              @default(false) @map("round_to_99")
  startsAt            DateTime?            @map("starts_at")
  endsAt              DateTime?            @map("ends_at")
  status              SaleCampaignStatus   @default(DRAFT)
  scope               CampaignScope        @default(ALL)
  scopeValue          String[]             @default([]) @map("scope_value")
  stackableWithCoupons Boolean             @default(true) @map("stackable_with_coupons")
  createdBy           String?              @map("created_by")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  products            SaleCampaignProduct[]

  @@index([status])
  @@index([startsAt, endsAt])
  @@map("sale_campaigns")
}

model SaleCampaignProduct {
  id                     String          @id @default(cuid())
  campaignId             String          @map("campaign_id")
  productId              String          @map("product_id")
  variantId              String?         @map("variant_id")
  originalPrice          Decimal         @map("original_price") @db.Decimal(10, 2)
  originalCompareAtPrice Decimal?        @map("original_compare_at_price") @db.Decimal(10, 2)
  salePrice              Decimal         @map("sale_price") @db.Decimal(10, 2)
  appliedAt              DateTime        @default(now()) @map("applied_at")
  campaign               SaleCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product                Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant                ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId, variantId])
  @@index([campaignId])
  @@index([productId])
  @@index([variantId])
  @@map("sale_campaign_products")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  MULTIPLIER
}

enum SaleCampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

enum CampaignScope {
  ALL
  CATEGORY
  WAREHOUSE
  SELECTED
  TAG
}

model Wholesaler {
  id                    String   @id @default(cuid())
  key                   String   @unique
  name                  String
  baselinkerInventoryId String?  @unique @map("baselinker_inventory_id")
  prefix                String   @default("")
  skuPrefix             String?  @map("sku_prefix")
  location              String?
  warehouseDisplayName  String?  @map("warehouse_display_name")
  aliases               String[] @default([])
  color                 String   @default("#6b7280")
  isActive              Boolean  @default(true) @map("is_active")
  skipInSync            Boolean  @default(false) @map("skip_in_sync")
  hasPriceRules         Boolean  @default(false) @map("has_price_rules")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([sortOrder])
  @@map("wholesalers")
}
