model EmailTemplate {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  description       String?
  subject           String
  content           String   @db.Text
  category          String   @default("DELIVERY_DELAY")
  includesDiscount  Boolean  @default(false) @map("includes_discount")
  discountPercent   Int?     @map("discount_percent")
  discountValidDays Int?     @map("discount_valid_days")
  isActive          Boolean  @default(true) @map("is_active")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("email_templates")
